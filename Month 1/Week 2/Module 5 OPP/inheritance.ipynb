    "class Animal:\n",
    "    def speak(self):\n",
    "        print(\"Animal makes sound\")\n",
    "\n",
    "class Dog(Animal):   # Dog inherits Animal\n",
    "    def __init__(self,hello,world):\n",
    "        self.hello = hello\n",
    "        self.world = world\n",
    "\n",
    "\n",
    "a  = 50 \n",
    "d = Dog('no',a)\n",
    "\n",
    "print(d.hello, end = ' ')\n",
    "print(d.world)"
   ]
