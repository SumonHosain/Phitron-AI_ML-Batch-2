   "source": [
    "try:\n",
    "    # risky code\n",
    "except SomeError:\n",
    "    # handle error\n",
    "else:\n",
    "    # runs if no error\n",
    "finally:\n",
    "    # always runs\n",
    "\n",
    "Think like this:\n",
    "try → I will try to do something\n",
    "except → If something goes wrong, handle it\n",
    "else → If everything is fine, do this\n",
    "finally → Always do this (cleanup)"
   ]
