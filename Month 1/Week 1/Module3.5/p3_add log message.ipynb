    "def add_log(Add_log_message):\n",
    "    with open('log.txt','w+') as file:\n",
    "        file.write(Add_log_message)\n",
    "        file.seek(0)\n",
    "        print(file.read())\n",
    "        \n",
    "\n",
    "add_log('User loged in')\n",
    "add_log('Login successfull')\n",
    "        \n"
   ]
