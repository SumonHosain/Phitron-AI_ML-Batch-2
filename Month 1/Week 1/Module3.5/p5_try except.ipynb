   "source": [
    "def safe_read(file_name):\n",
    "    try:\n",
    "        with open (file_name,'r') as file:\n",
    "            x= file.read()\n",
    "    except:\n",
    "        print('Missing file')\n",
    "    else:\n",
    "        print(x)\n",
    "    finally:\n",
    "        print('Operation Complete')\n",
    "\n",
    "\n",
    "safe_read('sample.txt')"
   ]
  },
