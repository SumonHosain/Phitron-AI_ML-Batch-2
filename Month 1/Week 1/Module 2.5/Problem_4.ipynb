    "base = int(input('Entre your Base'))\n",
    "exponent = int(input('Entre your Exponent'))\n",
    "def power(base, exponent):\n",
    "    if exponent >0:\n",
    "        x = base**exponent\n",
    "        return x\n",
    "    else:\n",
    "        x = base ** 2\n",
    "        return x        \n",
    "power(base,exponent)"
